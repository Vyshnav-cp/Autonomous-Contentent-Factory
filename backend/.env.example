# Autonomous Content Factory - Environment Configuration

# ============================================================================
# REQUIRED: OpenAI API Configuration
# ============================================================================

# Your OpenAI API key
# Get it from: https://platform.openai.com/api-keys
# Do NOT commit this to version control!
OPENAI_API_KEY=sk-your-api-key-here

# ============================================================================
# OPTIONAL: Server Configuration
# ============================================================================

# Server port (default: 8000)
PORT=8000

# Server host (default: 0.0.0.0)
HOST=0.0.0.0

# Environment (development or production)
# development: enables auto-reload and debug mode
# production: runs with multiple workers
ENVIRONMENT=development

# ============================================================================
# OPTIONAL: Database Configuration
# ============================================================================

# Database URL (for future use)
# DATABASE_URL=postgresql://user:password@localhost:5432/acf

# ============================================================================
# OPTIONAL: Logging Configuration
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# ============================================================================
# OPTIONAL: Feature Flags
# ============================================================================

# Enable/disable specific features
# ENABLE_EMAIL_GENERATION=true
# ENABLE_FILE_UPLOAD=true
# ENABLE_BATCH_PROCESSING=true

# ============================================================================
# Instructions
# ============================================================================

# 1. Copy this file to .env
#    cp .env.example .env

# 2. Update .env with your actual values
#    Replace 'sk-your-api-key-here' with your OpenAI API key

# 3. IMPORTANT: Add .env to .gitignore
#    The .env file should NEVER be committed to version control

# 4. Run the backend
#    bash start_server.sh

# ============================================================================
